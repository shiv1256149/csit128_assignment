<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Services" }) %>
<body class="bg-slate-100 min-h-screen">
 <%- include("../partials/admin-head", { title: "services" }) %>

  <main class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-semibold text-slate-800 mb-6"><%= editing ? "Edit service" : "New service" %></h1>

    <form method="POST" action="<%= editing ? `/admin/services/${editing.id}` : '/admin/services' %>"
          class="bg-white rounded-lg shadow p-6 mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div>
        <label class="block text-sm text-slate-600 mb-1">Slug</label>
        <input name="slug" required value="<%= editing ? editing.slug : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Name</label>
        <input name="name" required value="<%= editing ? editing.name : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Icon</label>
        <input name="icon" value="<%= editing ? (editing.icon || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Starting price</label>
        <input name="starting_price" value="<%= editing ? (editing.starting_price || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm text-slate-600 mb-1">Summary</label>
        <input name="summary" value="<%= editing ? (editing.summary || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm text-slate-600 mb-1">Details</label>
        <textarea name="details" rows="3" class="w-full border rounded px-3 py-2"><%= editing ? (editing.details || '') : '' %></textarea>
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Order</label>
        <input type="number" name="order_index" value="<%= editing ? editing.order_index : 0 %>" class="w-full border rounded px-3 py-2" />
      </div>
      <% if (editing) { %>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_active" id="is_active" <%= editing.is_active ? "checked" : "" %> />
          <label for="is_active" class="text-sm text-slate-600">Visible on site</label>
        </div>
      <% } %>
      <div class="md:col-span-2 flex gap-3">
        <button type="submit" class="bg-slate-900 text-white px-4 py-2 rounded hover:bg-slate-700">
          <%= editing ? "Save changes" : "Create service" %>
        </button>
        <% if (editing) { %>
          <a href="/admin/services" class="px-4 py-2 rounded border">Cancel</a>
        <% } %>
      </div>
    </form>

    <table class="w-full bg-white rounded-lg shadow overflow-hidden text-sm">
      <thead class="bg-slate-50 text-slate-500 text-left">
        <tr><th class="px-4 py-2">Name</th><th class="px-4 py-2">Starting price</th><th class="px-4 py-2">Active</th><th class="px-4 py-2"></th></tr>
      </thead>
      <tbody>
        <% services.forEach(s => { %>
          <tr class="border-t">
            <td class="px-4 py-2"><%= s.name %></td>
            <td class="px-4 py-2"><%= s.starting_price || "—" %></td>
            <td class="px-4 py-2"><%= s.is_active ? "Yes" : "No" %></td>
            <td class="px-4 py-2 flex gap-2">
              <a href="/admin/services/<%= s.id %>/edit" class="text-blue-600 hover:underline">Edit</a>
              <form method="POST" action="/admin/services/<%= s.id %>/delete" onsubmit="return confirm('Delete this service?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="text-red-600 hover:underline">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>
