<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Products" }) %>

<body class="bg-slate-100 min-h-screen">

 <%- include("../partials/admin-head", { title: "products" }) %>


  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="mb-8">
      <h1 class="text-4xl font-bold text-slate-900">
        Products
      </h1>

      <p class="text-slate-500 mt-2">
        Manage your product catalog
      </p>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-8">

      <h2 class="text-xl font-semibold mb-6">
        <%= editing ? "Edit Product" : "Create Product" %>
      </h2>

      <form
        method="POST"
        action="<%= editing ? `/admin/products/${editing.id}` : '/admin/products' %>"
        class="grid md:grid-cols-2 gap-5">

        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Product Name
          </label>
          <input
            name="name"
            required
            value="<%= editing ? editing.name : '' %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Slug
          </label>
          <input
            name="slug"
            required
            value="<%= editing ? editing.slug : '' %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3">
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Category
          </label>
          <input
            name="category"
            value="<%= editing ? (editing.category || '') : '' %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3">
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Price
          </label>
          <input
            name="price"
            value="<%= editing ? (editing.price || '') : '' %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3">
        </div>

        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Image URL
          </label>
          <input
            name="image_url"
            value="<%= editing ? (editing.image_url || '') : '' %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3">
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Display Order
          </label>
          <input
            type="number"
            name="order_index"
            value="<%= editing ? editing.order_index : 0 %>"
            class="w-full border border-slate-300 rounded-xl px-4 py-3">
        </div>

        <% if (editing) { %>
        <div class="flex items-center gap-3 pt-8">
          <input
            type="checkbox"
            name="is_active"
            id="is_active"
            <%= editing.is_active ? "checked" : "" %>>

          <label for="is_active" class="text-sm text-slate-700">
            Visible on Website
          </label>
        </div>
        <% } %>

        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Description
          </label>

          <textarea
            rows="4"
            name="description"
            class="w-full border border-slate-300 rounded-xl px-4 py-3"><%= editing ? (editing.description || '') : '' %></textarea>
        </div>

        <div class="md:col-span-2 flex gap-3">

          <button
            type="submit"
            class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl transition">
            <%= editing ? "Save Changes" : "Create Product" %>
          </button>

          <% if (editing) { %>
          <a
            href="/admin/products"
            class="border border-slate-300 px-6 py-3 rounded-xl hover:bg-slate-50 transition">
            Cancel
          </a>
          <% } %>

        </div>

      </form>

    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">

      <div class="p-6 border-b border-slate-200 flex justify-between items-center">
        <h2 class="text-xl font-semibold">
          Product List
        </h2>

        <span class="text-sm text-slate-500">
          <%= products.length %> Products
        </span>
      </div>

      <div class="overflow-x-auto">

        <table class="w-full">

          <thead class="bg-slate-50">

            <tr>
              <th class="text-left px-6 py-4 font-semibold text-slate-700">Product</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-700">Category</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-700">Price</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-700">Status</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-700">Actions</th>
            </tr>

          </thead>

          <tbody>

            <% products.forEach(p => { %>

            <tr class="border-t hover:bg-slate-50 transition">

              <td class="px-6 py-4">
                <div class="font-medium text-slate-900">
                  <%= p.name %>
                </div>
              </td>

              <td class="px-6 py-4 text-slate-600">
                <%= p.category || "—" %>
              </td>

              <td class="px-6 py-4 text-slate-600">
                <%= p.price || "—" %>
              </td>

              <td class="px-6 py-4">

                <% if (p.is_active) { %>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-medium">
                  Active
                </span>
                <% } else { %>
                <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-medium">
                  Hidden
                </span>
                <% } %>

              </td>

              <td class="px-6 py-4">

                <div class="flex items-center gap-4">

                  <a
                    href="/admin/products/<%= p.id %>/edit"
                    class="text-indigo-600 hover:text-indigo-800 font-medium">
                    Edit
                  </a>

                  <form
                    method="POST"
                    action="/admin/products/<%= p.id %>/delete"
                    onsubmit="return confirm('Delete this product?');">

                    <input
                      type="hidden"
                      name="_csrf"
                      value="<%= csrfToken %>" />

                    <button
                      type="submit"
                      class="text-red-600 hover:text-red-800 font-medium">
                      Delete
                    </button>

                  </form>

                </div>

              </td>

            </tr>

            <% }) %>

          </tbody>

        </table>

      </div>

    </div>

  </main>

</body>
</html>
