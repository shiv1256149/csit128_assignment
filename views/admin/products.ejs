<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Products" }) %>
<body class="bg-slate-100 min-h-screen">
  <%- include("../partials/admin-nav") %>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-semibold text-slate-800 mb-6"><%= editing ? "Edit product" : "New product" %></h1>

    <form method="POST" action="<%= editing ? `/admin/products/${editing.id}` : '/admin/products' %>"
          class="bg-white rounded-lg shadow p-6 mb-8 grid grid-cols-1 md:grid-cols-2 gap-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div>
        <label class="block text-sm text-slate-600 mb-1">Slug</label>
        <input name="slug" required value="<%= editing ? editing.slug : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Name</label>
        <input name="name" required value="<%= editing ? editing.name : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Category</label>
        <input name="category" value="<%= editing ? (editing.category || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Price</label>
        <input name="price" value="<%= editing ? (editing.price || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Image URL</label>
        <input name="image_url" value="<%= editing ? (editing.image_url || '') : '' %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm text-slate-600 mb-1">Order</label>
        <input type="number" name="order_index" value="<%= editing ? editing.order_index : 0 %>" class="w-full border rounded px-3 py-2" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm text-slate-600 mb-1">Description</label>
        <textarea name="description" rows="3" class="w-full border rounded px-3 py-2"><%= editing ? (editing.description || '') : '' %></textarea>
      </div>
      <% if (editing) { %>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_active" id="is_active" <%= editing.is_active ? "checked" : "" %> />
          <label for="is_active" class="text-sm text-slate-600">Visible on site</label>
        </div>
      <% } %>
      <div class="md:col-span-2 flex gap-3">
        <button type="submit" class="bg-slate-900 text-white px-4 py-2 rounded hover:bg-slate-700">
          <%= editing ? "Save changes" : "Create product" %>
        </button>
        <% if (editing) { %>
          <a href="/admin/products" class="px-4 py-2 rounded border">Cancel</a>
        <% } %>
      </div>
    </form>

    <table class="w-full bg-white rounded-lg shadow overflow-hidden text-sm">
      <thead class="bg-slate-50 text-slate-500 text-left">
        <tr><th class="px-4 py-2">Name</th><th class="px-4 py-2">Category</th><th class="px-4 py-2">Price</th><th class="px-4 py-2">Active</th><th class="px-4 py-2"></th></tr>
      </thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr class="border-t">
            <td class="px-4 py-2"><%= p.name %></td>
            <td class="px-4 py-2"><%= p.category || "—" %></td>
            <td class="px-4 py-2"><%= p.price || "—" %></td>
            <td class="px-4 py-2"><%= p.is_active ? "Yes" : "No" %></td>
            <td class="px-4 py-2 flex gap-2">
              <a href="/admin/products/<%= p.id %>/edit" class="text-blue-600 hover:underline">Edit</a>
              <form method="POST" action="/admin/products/<%= p.id %>/delete" onsubmit="return confirm('Delete this product?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="text-red-600 hover:underline">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>
