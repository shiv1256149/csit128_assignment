<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Login" }) %>
<body class="bg-slate-100 min-h-screen flex items-center justify-center">
  <form method="POST" action="/admin/login" class="bg-white shadow-md rounded-lg p-8 w-full max-w-sm">
    <h1 class="text-xl font-semibold mb-6 text-slate-800">Admin Login</h1>
    <% if (error) { %>
      <p class="text-sm text-red-600 mb-4"><%= error %></p>
    <% } %>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label class="block text-sm text-slate-600 mb-1">Email</label>
    <input type="email" name="email" required class="w-full border rounded px-3 py-2 mb-4" />
    <label class="block text-sm text-slate-600 mb-1">Password</label>
    <input type="password" name="password" required class="w-full border rounded px-3 py-2 mb-6" />
    <button type="submit" class="w-full bg-slate-900 text-white rounded py-2 hover:bg-slate-700">Log in</button>
  </form>
</body>
</html>
