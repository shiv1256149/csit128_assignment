<!DOCTYPE html>

<html lang="en">
<%- include("../partials/admin-head", { title: "Dashboard" }) %>

<body class="bg-slate-100 min-h-screen">

<%- include("../partials/admin-nav") %>

  <main class="max-w-7xl mx-auto px-6 py-8">

```
<div class="mb-8">
  <h1 class="text-4xl font-bold text-slate-900">
    Dashboard.
  </h1>

  <p class="text-slate-500 mt-2">
    Welcome back, <span class="font-semibold"><%= admin.name %></span>
  </p>
</div>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

  <% Object.entries(counts).forEach(([label, value]) => { %>

  <div
    class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">

    <div class="flex justify-between items-center">

      <div>
        <p class="text-sm uppercase tracking-wide text-slate-500">
          <%= label.replaceAll("_", " ") %>
        </p>

        <h2 class="text-4xl font-bold text-slate-900 mt-2">
          <%= value %>
        </h2>
      </div>

      <div
        class="w-14 h-14 rounded-xl bg-indigo-100 text-indigo-600 flex items-center justify-center text-xl"
      </div>

    </div>

  </div>

  <% }) %>

</div>
<section class="mt-10">

  <h2 class="text-xl font-semibold text-slate-900 mb-4">
    Quick Actions
  </h2>

  <div class="grid md:grid-cols-3 gap-4">

    <a
      href="/admin/products"
      class="bg-indigo-600 hover:bg-indigo-700 text-white p-5 rounded-xl shadow transition">
      Manage Products
    </a>

    <a
      href="/admin/services"
      class="bg-emerald-600 hover:bg-emerald-700 text-white p-5 rounded-xl shadow transition">
      Manage Services
    </a>

    <a
      href="/admin/orders"
      class="bg-orange-600 hover:bg-orange-700 text-white p-5 rounded-xl shadow transition">
      View Orders
    </a>

  </div>

</section>
```

  </main>

</body>
</html>
