<!DOCTYPE html>
<html lang="en">
<%- include("../partials/admin-head", { title: "Dashboard" }) %>
<body class="bg-slate-100 min-h-screen">
  <%- include("../partials/admin-nav") %>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-semibold text-slate-800 mb-6">Dashboard</h1>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
      <% Object.entries(counts).forEach(([label, value]) => { %>
        <div class="bg-white rounded-lg shadow p-5">
          <p class="text-sm text-slate-500 capitalize"><%= label %></p>
          <p class="text-3xl font-bold text-slate-800"><%= value %></p>
        </div>
      <% }) %>
    </div>
  </main>
</body>
</html>
