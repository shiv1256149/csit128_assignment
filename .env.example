PORT=3010
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=veyra
DB_PASSWORD=change-me
DB_NAME=veyra

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=2h

SESSION_SECRET=change-me-to-a-different-long-random-string

# Set to "true" only when this app is actually served over HTTPS (e.g.
# behind a reverse proxy doing TLS termination). Leave "false" for plain
# HTTP deployments (local dev, docker-compose without TLS) - the browser
# silently drops Secure cookies over HTTP, which would lock out every login.
COOKIE_SECURE=false

# Only set this if the frontend is served from a different origin than
# this API (e.g. a separate docker-compose service). Leave unset for a
# same-origin deployment (Express serving both the API and the static site).
CORS_ORIGIN=

# Used only by the seed script to bootstrap the first admin account.
ADMIN_EMAIL=admin@veyra.tech
ADMIN_PASSWORD=change-me-strong-password
